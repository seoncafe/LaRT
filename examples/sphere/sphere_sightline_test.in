!------------------------------------------------------------------------
! Cartesian-mode sight-line tau test for the standalone make_sightline_tau.x
! driver.  Same physical setup as t1tau4.in but with an observer block
! (alpha/beta/distance/nxim/nyim) so the sight-line maps can be projected.
!------------------------------------------------------------------------
&parameters
 par%temperature = 1.0e1
 par%taumax      = 1.0e4
 par%DGR         = 0.0
 par%spectral_type = 'voigt'
 par%nx = 101, par%ny = 101, par%nz = 101
 par%nxfreq = 121
 par%rmax   = 1.0
 par%xyz_symmetry = .false.

 ! Observer
 par%nxim     = 65
 par%nyim     = 65
 par%alpha    = 0.0
 par%beta     = 0.0
 par%distance = 100.0
 par%out_file = 'sphere_sightline_test.fits.gz'
/
