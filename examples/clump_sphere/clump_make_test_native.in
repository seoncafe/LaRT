!------------------------------------------------------------------------
! Native-generation reference for the round-trip test.  Identical physics
! to clump_make_test_load.in but lets LaRT regenerate the clumps
! internally with the same iseed.  The FITS clump tables produced by
! this run and by make_clumps.x with clump_make_test.in must agree
! byte-for-byte (modulo float32 precision).
!------------------------------------------------------------------------
&parameters
 par%use_clump_medium     = .true.
 par%rmax                 = 1.0
 par%clump_radius         = 0.01
 par%clump_f_cov          = 5.0
 par%clump_tau0           = 1.0e3
 par%temperature          = 1.0e4
 par%clump_sigma_v        = 0.0
 par%no_photons           = 1e5
 par%spectral_type        = 'voigt'
 par%nxfreq               = 301
 par%velocity_min         = -100.0
 par%velocity_max         =  100.0
 par%nx = 11, par%ny = 11, par%nz = 11
 par%save_clump_info      = .true.
 par%iseed                = 12345
 par%out_file             = 'clump_make_test_native.fits.gz'
/
